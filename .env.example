# =============================================================================
# Database
# =============================================================================
# Default: matches the docker-compose.yml in ops/ — run `docker compose up -d`
# from the ops/ directory and this URL works out of the box. See ops/local-db.md
# for the full local workflow (migrate, dump from Neon, reset, etc.).
DATABASE_URL=postgresql://loltricks:loltricks@localhost:5432/loltricks?schema=public

# Production / Neon (example). Use the pooled connection string that Neon
# generates for you (host ends in `-pooler…`) — Vercel serverless needs it.
# DATABASE_URL=postgresql://<user>:<password>@<project>-pooler.neon.tech/<db>?sslmode=require

# =============================================================================
# Riot API
# =============================================================================
# Dev keys expire every 24h — regenerate at https://developer.riotgames.com/.
# You can keep up to three keys live at once and pick which one a script uses
# via `--key=1|2|3` (see ops/shared.cjs). Only the first is required.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# RIOT_API_KEY_SECOND=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# RIOT_API_KEY_THIRD=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =============================================================================
# Server
# =============================================================================
CRON_SECRET=your-secret-here
PORT=3001
